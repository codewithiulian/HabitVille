{
  "name": "habitville",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/gen-config.js && node scripts/gen-asset-catalog.js",
    "dev": "concurrently -n next,tunnel,open \"next dev\" \"cloudflared tunnel run --url http://localhost:3000 habitville\" \"node scripts/open-browser.js\"",
    "predev-local": "node scripts/gen-config.js && node scripts/gen-asset-catalog.js",
    "dev-local": "next dev --turbopack",
    "prebuild": "node scripts/gen-config.js && node scripts/gen-asset-catalog.js",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "predev2": "node scripts/gen-config.js && node scripts/gen-asset-catalog.js",
    "dev2": "concurrently -n next,tunnel \"next dev --port 3001\" \"cloudflared tunnel run --url http://localhost:3001 habitville2\""
  },
  "dependencies": {
    "dexie": "^4.3.0",
    "dexie-react-hooks": "^4.2.0",
    "framer-motion": "^12.35.1",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "pixi.js": "^8.16.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "yaml": "^2.8.2"
  }
}
